datasource db {
  provider  = "postgresql"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

// ==========================================
// 1. MULTI-TENANCY & UTILISATEURS
// ==========================================

enum TenantPlan {
  FREE
  STANDARD
  PREMIUM
  ENTERPRISE
}

model Company {
  id          String     @id @default(uuid())
  name        String
  legalName   String?
  taxId       String?    @unique // NINEA au Sénégal
  address     String?
  logoUrl     String?
  plan        TenantPlan @default(STANDARD)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  users       User[]
  vehicles    Vehicle[]
  routes      Route[]
  trips       Trip[]
  wallets     Wallet[]

  @@map("companies")
}

enum UserRole {
  SUPER_ADMIN     // Équipe Aller-Retour
  TENANT_ADMIN    // Gestionnaire de GIE / Transporteur
  DISPATCHER      // Guichetier / Chef de gare
  DRIVER          // Chauffeur (Affilié ou Libre)
  PASSENGER       // Client / Voyageur
}

model User {
  id            String    @id @default(uuid())
  companyId     String?   // Obligatoire pour TENANT_ADMIN et DISPATCHER
  company       Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  email         String?   @unique
  phone         String    @unique // Numéro de téléphone principal (clé d'auth Mobile Money)
  phoneVerified Boolean   @default(false)
  passwordHash  String?   // Optionnel pour login par OTP/PIN Wave
  fullName      String
  avatarUrl     String?
  role          UserRole  @default(PASSENGER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  driverProfile DriverProfile?
  bookings      Booking[]
  wallets       Wallet[]
  seatLocks     SeatLock[]

  failedAttempts Int       @default(0)
  blockedUntil   DateTime?

  colisPoints    Int       @default(30)
  transportPoints Int      @default(20)

  @@index([phone])
  @@index([companyId])
  @@map("users")
}

// ==========================================
// 2. CHAUFFEURS & VÉHICULES
// ==========================================

enum DriverType {
  AFFILIATED // Rattaché à une compagnie/GIE
  FREELANCE  // Chauffeur indépendant sur la Marketplace
}

enum KYCStatus {
  PENDING
  VERIFIED
  REJECTED
}

model DriverProfile {
  id              String     @id @default(uuid())
  userId          String     @unique
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            DriverType @default(AFFILIATED)
  licenseNumber   String     @unique
  licenseExpiry   DateTime
  licenseFrontUrl String?
  licenseBackUrl  String?
  kycStatus       KYCStatus  @default(PENDING)
  rating          Float      @default(5.0)
  totalTrips      Int        @default(0)
  isVerified      Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  trips           Trip[]

  @@map("driver_profiles")
}

enum VehicleType {
  BUS_50
  MINIBUS_30
  MINIBUS_15
  TAXI_7_PLACES
}

enum VehicleStatus {
  ACTIVE
  IN_MAINTENANCE
  INSPECTION_EXPIRED
  INACTIVE
}

model Vehicle {
  id               String        @id @default(uuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  plateNumber      String        @unique
  type             VehicleType
  capacity         Int           // Nombre de sièges passagers
  brand            String?
  model            String?
  year             Int?
  status           VehicleStatus @default(ACTIVE)
  insuranceExpiry  DateTime
  inspectionExpiry DateTime      // Visite technique
  photoUrl         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  trips            Trip[]

  @@index([companyId])
  @@index([plateNumber])
  @@map("vehicles")
}

// ==========================================
// 3. MOBILITÉ, GARES & LIGNES
// ==========================================

model Station {
  id                String   @id @default(uuid())
  name              String   // ex: Gare Routière de Baux Maraîchers
  city              String   // ex: Dakar
  country           String   @default("SN") // Code ISO
  latitude          Float
  longitude         Float
  geofenceRadiusMeters Int   @default(200) // Rayon en mètres pour check-in automatique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  routesOrigin      Route[]  @relation("RouteOrigin")
  routesDestination Route[]  @relation("RouteDestination")

  @@index([city, country])
  @@map("stations")
}

model Route {
  id                   String   @id @default(uuid())
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  name                 String   // ex: Dakar - Touba
  originStationId      String
  originStation        Station  @relation("RouteOrigin", fields: [originStationId], references: [id], onDelete: Restrict)
  destinationStationId String
  destinationStation   Station  @relation("RouteDestination", fields: [destinationStationId], references: [id], onDelete: Restrict)
  
  distanceKm           Float
  estimatedDurationMins Int
  defaultPrice         Float    // Prix par défaut en FCFA
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  trips                Trip[]

  @@index([companyId])
  @@index([originStationId, destinationStationId])
  @@map("routes")
}

enum TripStatus {
  SCHEDULED
  BOARDING
  IN_TRANSIT
  ARRIVED
  COMPLETED
  CANCELLED
}

model Trip {
  id              String     @id @default(uuid())
  companyId       String
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  routeId         String
  route           Route      @relation(fields: [routeId], references: [id], onDelete: Restrict)
  vehicleId       String
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driverId        String
  driver          DriverProfile @relation(fields: [driverId], references: [id], onDelete: Restrict)

  departureTime   DateTime
  arrivalTime     DateTime?
  status          TripStatus @default(SCHEDULED)
  pricePerSeat    Float      // Prix effectif de la place sur ce départ
  isMarketplace   Boolean    @default(false) // Trajet de chauffeur libre
  isLocked        Boolean    @default(false) // Verrouillage du trajet pour bloquer les réservations publiques
  seatsOffered      Int        @default(4)
  initialPassengers Int        @default(0)
  currentLat        Float?
  currentLng        Float?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  bookings        Booking[]
  parcels         Parcel[]
  seatLocks       SeatLock[]

  @@index([companyId])
  @@index([routeId])
  @@index([departureTime])
  @@map("trips")
}

// ==========================================
// 4. RÉSERVATION, BILLETS & COLIS
// ==========================================

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  BOARDED
  CANCELLED
}

enum PaymentMethod {
  WAVE
  ORANGE_MONEY
  FREE_MONEY
  MTN_MOMO
  WALLET
  CASH
}

model Booking {
  id              String        @id @default(uuid())
  tripId          String
  trip            Trip          @relation(fields: [tripId], references: [id], onDelete: Restrict)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  
  seatNumber      Int
  qrCodeToken     String        @unique // Token chiffré anticopie
  status          BookingStatus @default(PENDING_PAYMENT)
  amountPaid      Float
  paymentMethod   PaymentMethod
  paymentRef      String?       // Transaction ID de Wave / OM
  boardedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // @@unique removed because it prevents seat reuse after cancellations/expirations
  @@index([userId])
  @@index([qrCodeToken])
  @@map("bookings")
}

model SeatLock {
  id          String   @id @default(uuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  seatNumber  Int
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lockedUntil DateTime
  createdAt   DateTime @default(now())

  @@unique([tripId, seatNumber])
  @@map("seat_locks")
}

enum ParcelStatus {
  REGISTERED
  ACCEPTED
  IN_TRANSIT
  DELIVERED
  LOST
}

model Parcel {
  id              String       @id @default(uuid())
  tripId          String
  trip            Trip         @relation(fields: [tripId], references: [id], onDelete: Restrict)
  
  senderName      String
  senderPhone     String
  recipientName   String
  recipientPhone  String
  weightKg        Float
  price           Float
  trackingCode    String       @unique
  deliveryCode    String?

  status          ParcelStatus @default(REGISTERED)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  acceptedAt      DateTime?
  inTransitAt     DateTime?
  deliveredAt     DateTime?

  @@index([trackingCode])
  @@map("parcels")
}

// ==========================================
// 5. FINANCES, WALLETS & ESCROW
// ==========================================

enum WalletType {
  PASSENGER_WALLET
  DRIVER_WALLET
  COMPANY_WALLET
  ESCROW_WALLET
  PLATFORM_TREASURY
  GOVERNMENT_TAX_WALLET
  PAYMENT_GATEWAY_WALLET
}

model Wallet {
  id              String        @id @default(uuid())
  type            WalletType
  currency        String        @default("XOF")
  balance         Float         @default(0.0)
  
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId       String?
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  transactionsDebit  Transaction[] @relation("WalletDebit")
  transactionsCredit Transaction[] @relation("WalletCredit")

  @@index([userId])
  @@index([companyId])
  @@map("wallets")
}

enum TransactionType {
  DEPOSIT            // Dépôt par Mobile Money
  WITHDRAWAL         // Retrait vers compte Wave/OM
  TICKET_PURCHASE    // Achat d'un billet
  ESCROW_HOLD        // Mise en séquestre du paiement
  ESCROW_RELEASE     // Libération des fonds au chauffeur/transporteur
  COMMISSION_FEE     // Prélèvement commission plateforme
  TAX_DEDUCTION      // Prélèvement taxes d'État / redevance gare
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Transaction {
  id              String            @id @default(uuid())
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  amount          Float
  currency        String            @default("XOF")
  reference       String?           @unique // Reference externe de paiement
  description     String?
  
  sourceWalletId  String?
  sourceWallet    Wallet?           @relation("WalletDebit", fields: [sourceWalletId], references: [id], onDelete: Restrict)
  targetWalletId  String?
  targetWallet    Wallet?           @relation("WalletCredit", fields: [targetWalletId], references: [id], onDelete: Restrict)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([sourceWalletId])
  @@index([targetWalletId])
  @@index([reference])
  @@map("transactions")
}

// ==========================================
// 6. SYSTÈME GÉOGRAPHIQUE NATIONAL (SÉNÉGAL)
// ==========================================

model GeoCountry {
  id        String      @id @default(uuid())
  code      String      @unique // ex: SN
  name      String      // ex: Sénégal
  currency  String      @default("FCFA")
  regions   GeoRegion[]

  @@map("geo_countries")
}

model GeoRegion {
  id          String           @id @default(uuid())
  countryId   String
  country     GeoCountry       @relation(fields: [countryId], references: [id], onDelete: Cascade)
  name        String           // ex: Dakar, Thiès
  departments GeoDepartment[]

  @@map("geo_regions")
}

model GeoDepartment {
  id        String      @id @default(uuid())
  regionId  String
  region    GeoRegion   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  name      String      // ex: Département de Dakar, Pikine
  cities    GeoCity[]

  @@map("geo_departments")
}

model GeoCity {
  id           String        @id @default(uuid())
  departmentId String
  department   GeoDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name         String        // ex: Dakar, Pikine, Rufisque
  communes     GeoCommune[]

  @@map("geo_cities")
}

model GeoCommune {
  id        String       @id @default(uuid())
  cityId    String
  city      GeoCity      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  name      String       // ex: Plateau, Médina, Touba Mosquée
  quarters  GeoQuarter[]

  @@map("geo_communes")
}

model GeoQuarter {
  id          String           @id @default(uuid())
  communeId   String
  commune     GeoCommune       @relation(fields: [communeId], references: [id], onDelete: Cascade)
  name        String           // ex: HLM 1, Parcelles Assainies, Darou Khoudoss
  subQuarters GeoSubQuarter[]

  @@map("geo_quarters")
}

model GeoSubQuarter {
  id        String        @id @default(uuid())
  quarterId String
  quarter   GeoQuarter    @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  name      String        // ex: Parcelles U1, Forage Baye Lahad
  landmarks GeoLandmark[]

  @@map("geo_sub_quarters")
}

model GeoLandmark {
  id           String         @id @default(uuid())
  subQuarterId String?
  subQuarter   GeoSubQuarter? @relation(fields: [subQuarterId], references: [id], onDelete: Cascade)
  name         String         // ex: Gare Routière Pompiers, Garage Bélel
  latitude     Float
  longitude    Float
  
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([name])
  @@map("geo_landmarks")
}

model AlloPriveRequest {
  id              String      @id @default(uuid())
  clientId        String
  clientName      String
  clientPhone     String
  origin          String
  destination     String
  departureDate   String
  price           Int
  type            String      @default("allo-prive") // "allo-prive" or "ordinaire"
  status          String      @default("PENDING") // PENDING, ACCEPTED, COMPLETED
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  applications    AlloPriveApplication[]

  @@map("allo_prive_requests")
}

model AlloPriveApplication {
  id              String      @id @default(uuid())
  requestId       String
  request         AlloPriveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  driverId        String
  driverName      String
  driverPhone     String
  driverRating    Float
  driverVerified  Boolean     @default(false)
  driverScore     Int         @default(100)
  status          String      @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("allo_prive_applications")
}
