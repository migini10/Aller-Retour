{
  "name": "@aller-retour/database",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "npm run generate && tsc",
    "generate": "dotenv -e ../../apps/api/.env -- prisma generate",
    "db:push": "dotenv -e ../../apps/api/.env -- prisma db push",
    "studio": "dotenv -e ../../apps/api/.env -- prisma studio",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
